---
import { cn } from "@lib/utils";

const {
  as: Tag = "a",
  class: className,
  href,
  heading,
  subheading,
  imagePath,
  altText,
} = Astro.props;

// TODO Chnage to links
---

<Tag
  class={cn(
    className,
    "group flex flex-col gap-y-3 rounded-2xl border border-border bg-card shadow-sm",
    href &&
      "transition-all duration-300 hover:shadow-lg hover:translate-y-[-2px]",
  )}
  href={href}
>
  <img
    src={imagePath}
    alt={altText}
    class="h-48 w-full rounded-t-2xl object-cover group-hover:brightness-110 transition-[brightness] duration-300"
    loading="eager"
  />
  <div class="flex flex-col gap-y-1 px-5 py-4">
    <h1
      class="text-lg font-semibold tracking-tight group-hover:text-accent transition-colors duration-300"
    >
      {heading}
    </h1>
    <h2 class="text-sm text-muted-foreground leading-relaxed">{subheading}</h2>
  </div>

  <slot />
</Tag>
