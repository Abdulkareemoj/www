---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { cn } from "@lib/utils";

const {
  as: Tag = "div",
  class: className,
  href,
  heading,
  subheading,
  date,
  imagePath,
  altText,
  imageClass,
} = Astro.props;
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/*.{jpeg,jpg,png,gif}",
);

if (imagePath) {
  if (!images[imagePath])
    throw new Error(
      `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif}"`,
    );
}
---

<Tag
  class={cn(
    className,
    "group relative rounded-2xl border border-border bg-card shadow-sm px-6 py-5",
    href &&
      "transition-all duration-300 hover:shadow-md hover:translate-y-[-1px]",
  )}
  href={href}
>
  {
    imagePath && (
      <Image
        src={images[imagePath]()}
        alt={altText}
        class={cn(
          "mb-3 md:absolute md:mb-0 group-hover:opacity-90 transition-opacity duration-300",
          imageClass,
        )}
        loading="eager"
      />
    )
  }
  <div class="flex flex-col gap-y-2">
    <div class="flex flex-col gap-y-1">
      <h1
        class="text-lg font-semibold tracking-tight group-hover:text-accent transition-colors duration-300"
      >
        {heading}
      </h1>
      <h2 class="text-sm text-muted-foreground">{subheading}</h2>
      <h2 class="text-xs text-muted-foreground">{date}</h2>
    </div>
    <slot />
  </div>
</Tag>
